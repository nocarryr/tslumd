{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchFileNames": [".github/workflows/codspeed.yml"],
      "matchPackageNames": ["actions/python-versions"],
      "allowedVersions": "3.13"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
